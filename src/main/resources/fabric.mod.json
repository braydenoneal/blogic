{
  "schemaVersion": 1,
  "id": "blogic",
  "version": "${version}",
  "name": "Blogic",
  "description": "Minecraft automation and storage mod",
  "authors": [
    "Brayden O'Neal"
  ],
  "license": "GPL-3.0",
  "icon": "assets/blogic/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "Blogic"
      }
    ],
    "client": [
      {
        "adapter": "kotlin",
        "value": "BlogicClient"
      }
    ],
    "fabric-datagen": [
      {
        "adapter": "kotlin",
        "value": "BlogicDataGenerator"
      }
    ]
  },
  "mixins": [],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.2",
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  }
}
